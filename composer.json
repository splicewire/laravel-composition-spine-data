{
    "name": "rushing/laravel-composition-spine-data",
    "description": "The composition spine's shared Data/DTO + schema authoring vocabulary: generation attributes, the data-schemas projection strategy, the angle layer, the BeatGrammar projector, and the structured-export I/O DTOs with 1:1 hydration. The heavy composition engine stays private; this is the surface satellites and the client share without it.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "rushing/laravel-data-schemas": "*",
        "spatie/laravel-data": "^4.0|^5.0"
    },
    "autoload": {
        "psr-4": {
            "Rushing\\CompositionSpineData\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rushing\\CompositionSpineData\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/stephenr85/laravel-data-schemas.git"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Rushing\\CompositionSpineData\\CompositionSpineDataServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        },
        "merge-plugin": {
            "include": ["composer.local.json"]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "wikimedia/composer-merge-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "pint": "@php -d memory_limit=512M vendor/bin/pint",
        "test": "@php vendor/bin/pest"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "wikimedia/composer-merge-plugin": "^2.1"
    }
}
